# Nexum forum API
GATE_SECRET=CHANGE_ME_MIN_32_CHARS
DATABASE_URL=postgresql+asyncpg://nexum@127.0.0.1:5432/nexum?sslmode=verify-full&sslrootcert=/opt/nexum/certs/ca.crt&sslcert=/opt/nexum/certs/forum.crt&sslkey=/opt/nexum/certs/forum.key

# Nexum escrow API
ESCROW_DB_URL=postgresql+asyncpg://freeescrow@127.0.0.1:5432/freeescrow?sslmode=verify-full&sslrootcert=/opt/nexum/certs/ca.crt&sslcert=/opt/nexum/certs/escrow.crt&sslkey=/opt/nexum/certs/escrow.key
ESCROW_ARBITER_TOKEN=CHANGE_ME_MIN_16_CHARS
ESCROW_ARBITER_NICK=server
XMR_WALLET_RPC_HOST=127.0.0.1
XMR_WALLET_RPC_PORT=28083
XMR_WALLET_RPC_USER=arb
XMR_WALLET_RPC_PASS=CHANGE_ME
XMR_ARBITER_WALLET_PASS=CHANGE_ME
# legacy = always enable multisig experimental attribute
# auto   = try native multisig first, fallback to experimental only if required
# strict = native multisig only (no experimental fallback)
XMR_MULTISIG_MODE=auto
# Minimum escrow amount accepted at create
ESCROW_MIN_AMOUNT_ATOMIC=1
# Fee reserve policy: max(floor, ceil(amount * bps / 10000))
ESCROW_FEE_FLOOR_ATOMIC=0
ESCROW_FEE_BPS=0
# Escrow HTTP -> nxms-escrow-orchestrator workflow bootstrap on create
NXMS_ESCROW_HTTP_ORCH_WORKFLOW_CREATE=false
NXMS_ESCROW_HTTP_ORCH_WORKFLOW_REQUIRED=false

# NX-AI <-> Escrow adapter
# mock = no remote calls (dev/tests), http = real escrow API integration
NX_AI_ESCROW_ADAPTER=mock
NX_AI_ESCROW_BASE_URL=http://127.0.0.1:8200
NX_AI_ESCROW_TIMEOUT_S=15
NX_AI_ESCROW_SELLER_NICK=nx_ai_provider
NX_AI_ESCROW_API_NICK=server
NX_AI_ESCROW_API_TOKEN=CHANGE_ME_ESCROW_QUERY_TOKEN
NX_AI_ESCROW_MEMO_PREFIX=nx-ai
